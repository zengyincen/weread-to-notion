# 微信读书 API 配置

# 微信读书 Cookie
# 将浏览器中得到的完整 Cookie 字符串粘贴到这里
# 注意：必须包含所有身份验证相关的字段，特别是wr_vid, wr_skey, wr_rt等微信读书特有字段
WEREAD_COOKIE=

# 可选：微信读书官方 API Key（推荐，获取地址：https://weread.qq.com/r/weread-skills）
# 未设置时，热力图脚本会尝试通过上面的 WEREAD_COOKIE 自动获取
WEREAD_API_KEY=

# Notion API 配置
NOTION_INTEGRATIONS="your_notion_api_key_here"
DATABASE_ID="your_notion_database_id_here"
NOTION_VERSION="2022-06-28"

# Notion 中用于展示热力图的现有 image 或 embed 块 ID
# 不配置时仍会生成并提交 SVG，只是不自动更新 Notion
HEATMAP_BLOCK_ID=

# 热力图配置（均为可选）
YEAR=
HEATMAP_NAME="微信读书"
HEATMAP_BACKGROUND_COLOR="#FFFFFF"
HEATMAP_EMPTY_COLOR="#EBEDF0"
HEATMAP_LOW_COLOR="#ACE7AE"
HEATMAP_MEDIUM_COLOR="#69C16E"
HEATMAP_HIGH_COLOR="#549F57"
HEATMAP_TEXT_COLOR="#24292F"

# 可选：配置数据库ID（用于书籍过滤）
# 如果设置此项，程序将根据配置数据库中的设置来过滤要同步的书籍
# 如果不设置，将同步所有书籍
CONFIG_DATABASE_ID="your_config_database_id_here"

# 可选：用户导入书籍封面处理配置
# 用于解决微信读书导入书籍的封面在 Notion 中无法显示的问题
# 两种方案：

# 方案 1：使用 Imgur 图床
# 你需要在 https://apidocs.imgur.com/ 注册应用并获取 Client ID
IMGUR_CLIENT_ID=

# 方案 2：使用 GitHub 仓库作为图床
# 你需要在 https://github.com/settings/tokens 生成个人访问令牌
GIT_TOKEN=
# 格式：用户名/仓库名，例如：yourname/yourrepo
GIT_REPO=

# 微信读书 API 配置

# 微信读书 Cookie
# 将浏览器中得到的完整 Cookie 字符串粘贴到这里
# 注意：必须包含所有身份验证相关的字段，特别是wr_vid, wr_skey, wr_rt等微信读书特有字段
WEREAD_COOKIE=

# Notion API 配置
NOTION_INTEGRATIONS="your_notion_api_key_here"
DATABASE_ID="your_notion_database_id_here"
NOTION_VERSION="2022-06-28"

# 可选：配置数据库ID（用于书籍过滤）
# 如果设置此项，程序将根据配置数据库中的设置来过滤要同步的书籍
# 如果不设置，将同步所有书籍
CONFIG_DATABASE_ID="your_config_database_id_here"

# 可选：用户导入书籍封面处理配置
# 用于解决微信读书导入书籍的封面在 Notion 中无法显示的问题
# 两种方案：

# 方案 1：使用 Imgur 图床
# 你需要在 https://apidocs.imgur.com/ 注册应用并获取 Client ID
IMGUR_CLIENT_ID=

# 方案 2：使用 GitHub 仓库作为图床
# 你需要在 https://github.com/settings/tokens 生成个人访问令牌
GIT_TOKEN=
# 格式：用户名/仓库名，例如：yourname/yourrepo
GIT_REPO=

